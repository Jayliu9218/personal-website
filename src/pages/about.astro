---
import BaseLayout from '../layouts/BaseLayout.astro';

const interests = [
  '材料微结构与显微表征',
  'FIB / SEM / TEM 相关实验流程',
  '科研数据整理与可复现分析',
  '个人知识库、技术写作与长期学习',
];

const skills = [
  {
    group: 'Research',
    items: ['Microscopy workflow', 'FIB sample prep', 'Experiment notes'],
  },
  {
    group: 'Code',
    items: ['HTML', 'CSS', 'JavaScript', 'Astro'],
  },
  {
    group: 'Writing',
    items: ['Technical notes', 'Documentation', 'Learning logs'],
  },
];
---

<BaseLayout
  pageTitle="关于"
  description="关于 Jay Liu 的研究兴趣、技术栈、个人记录方式和联系方式。"
>
  <main class="page-shell content-page">
    <section class="page-hero">
      <p class="section-kicker">About</p>
      <h1>我关注材料表征，也关注如何把研究过程记录得更清楚。</h1>
      <p>
        这个主页是我的公开索引：一部分用于整理实验与技术笔记，一部分用于记录学习、项目和长期问题。这里的内容会持续更新，并尽量保持准确、简洁、可追溯。
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/cv.pdf">下载 CV</a>
        <a class="button button-secondary" href="/blog/">浏览文章</a>
      </div>
    </section>

    <section class="about-layout">
      <div class="about-main">
        <h2>当前关注</h2>
        <p>
          我希望把材料、显微、代码和写作连接起来：在实验中积累问题，在分析中建立方法，在写作中沉淀判断。这个站点会优先收纳科研技术相关内容，也会保留一些个人项目和学习复盘。
        </p>
        <ul class="clean-list">
          {interests.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <aside class="profile-card">
        <h2>Profile</h2>
        <dl>
          <div>
            <dt>方向</dt>
            <dd>材料 / 显微 / 科研记录</dd>
          </div>
          <div>
            <dt>站点</dt>
            <dd>Astro 静态个人主页</dd>
          </div>
          <div>
            <dt>链接</dt>
            <dd>
              <a href="https://github.com/Jayliu9218" target="_blank" rel="noreferrer">GitHub</a>
              <span>/</span>
              <a
                href="https://scholar.google.com/citations?user=Q-i6GPwAAAAJ"
                target="_blank"
                rel="noreferrer"
              >
                Scholar
              </a>
            </dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="skill-section">
      <div class="section-heading">
        <p class="section-kicker">Toolkit</p>
        <h2>技能栈与工作方式</h2>
      </div>
      <div class="skill-grid">
        {skills.map((skill) => (
          <article class="feature-card compact">
            <h3>{skill.group}</h3>
            <div class="capability-cloud">
              {skill.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
