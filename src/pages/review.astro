---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = '知识复习';
const buildTimestamp = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'medium',
  timeStyle: 'short',
}).format(new Date());

const reviewImages = [
  {
    src: '/NotebookLM Mind Map.png',
    alt: '复习脑图',
  },
  {
    src: '/unnamed.png',
    alt: '复习图示',
  },
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body class="review-page">
    <Header />

    <main>
      <h1>{pageTitle}</h1>
      <p class="page-intro">
        按图片总览、互动问答、考核演练、疾病详情四个模块组织，支持手机端高效复习。
      </p>
      <p class="page-meta">最后更新于 {buildTimestamp}（构建）</p>

      <nav class="review-nav" aria-label="知识复习导航栏">
        <a href="#images">复习图片</a>
        <a href="#flashcards">闪卡问答</a>
        <a href="#exam">考核题</a>
        <a href="#summary">疾病详情</a>
        <a href="#essay">综合论述</a>
        <a href="#glossary">核心术语</a>
      </nav>

      <section id="images" class="hero-section">
        <h2>复习图片</h2>
        <p>点击图片可放大查看，支持上一张/下一张切换。</p>
        <div class="image-grid">
          {
            reviewImages.map((img, index) => (
              <figure class="review-image" data-index={index}>
                <img
                  src={img.src}
                  alt={img.alt}
                  loading="lazy"
                  data-gallery-image="true"
                />
                <figcaption>{img.alt}</figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section id="flashcards" class="accent-section">
        <h2>闪卡问答</h2>
        <p>先自己作答，再点击显示答案。可用“记住了/再练一次”进行训练。</p>
        <div class="quiz-panel flashcard-panel">
          <div class="quiz-stats" id="quiz-stats">加载题库中...</div>
          <article class="quiz-card flashcard-card" aria-live="polite">
            <h3 id="quiz-question">题目加载中...</h3>
            <p id="quiz-answer" hidden></p>
          </article>
          <div class="quiz-actions flashcard-actions">
            <button id="show-answer" type="button">显示答案</button>
            <button id="mark-known" type="button">记住了</button>
            <button id="mark-again" type="button">再练一次</button>
            <button id="next-question" type="button">下一题</button>
          </div>
        </div>

        <details class="all-qa">
          <summary>查看全部闪卡</summary>
          <div id="qa-grid" class="qa-grid"></div>
        </details>
      </section>

      <section id="exam" class="accent-section warm-section">
        <h2>临床技能考试考核题</h2>
        <p>考核题改为与闪卡一致的互动演练方式。</p>
        <div class="quiz-panel exam-panel">
          <div class="quiz-stats" id="exam-stats">加载考核题中...</div>
          <article class="quiz-card exam-card" aria-live="polite">
            <h3 id="exam-question">题目加载中...</h3>
            <p id="exam-answer" hidden>
              本模块为问答演练题，建议先口述作答，再查看参考答案。
            </p>
          </article>
          <div class="quiz-actions exam-actions">
            <button id="exam-show-answer" type="button">显示答题提示</button>
            <button id="exam-mark-done" type="button">完成此题</button>
            <button id="exam-mark-again" type="button">稍后再练</button>
            <button id="exam-next-question" type="button">下一题</button>
          </div>
        </div>

        <details class="all-qa">
          <summary>查看全部考核题</summary>
          <ol id="exam-list" class="exam-list"></ol>
        </details>
      </section>

      <section id="summary" class="accent-section cool-section">
        <h2>疾病名称与详情</h2>
        <div class="summary-layout">
          <div class="summary-list-box">
            <div class="table-tools">
              <label for="summary-search">疾病筛选：</label>
              <input
                id="summary-search"
                type="search"
                placeholder="输入疾病名称关键词"
              />
              <span id="summary-count"></span>
            </div>
            <ul id="summary-list" class="summary-list"></ul>
          </div>

          <article
            id="summary-detail"
            class="summary-detail"
            aria-live="polite"
          >
            <h3>请选择左侧疾病名称</h3>
            <p>选择后将在这里展示诊断依据、治疗原则、疾病特点等详细信息。</p>
          </article>
        </div>
      </section>

      <section id="essay" class="accent-section essay-section">
        <h2>综合论述</h2>
        <p>以题卡方式轮换展示，便于口述组织答案。</p>
        <div class="quiz-panel essay-panel">
          <div class="quiz-stats" id="essay-stats">加载综合论述中...</div>
          <article class="quiz-card essay-card-panel" aria-live="polite">
            <h3 id="essay-question">题目加载中...</h3>
            <p id="essay-hint" hidden>
              本部分仅展示论述题题目，请结合教材与笔记自行组织作答。
            </p>
          </article>
          <div class="quiz-actions essay-actions">
            <button id="essay-show-hint" type="button">显示答题提示</button>
            <button id="essay-mark-done" type="button">已掌握</button>
            <button id="essay-mark-again" type="button">再看一次</button>
            <button id="essay-next-question" type="button">下一题</button>
          </div>
        </div>

        <details class="all-qa">
          <summary>查看全部综合论述题</summary>
          <div id="essay-grid" class="qa-grid"></div>
        </details>
      </section>

      <section id="glossary" class="accent-section glossary-section">
        <h2>核心术语</h2>
        <p>以术语列表配合详情展示，便于快速切换与对照。</p>
        <div class="glossary-layout">
          <div class="glossary-list-box">
            <div class="table-tools">
              <span id="glossary-count"></span>
            </div>
            <ul id="glossary-list" class="summary-list glossary-cloud"></ul>
          </div>

          <article
            id="glossary-detail"
            class="summary-detail glossary-detail"
            aria-live="polite"
          >
            <h3>请选择左侧术语</h3>
            <p>选择后将在这里展示术语的定义与临床意义。</p>
          </article>
        </div>
      </section>

      <dialog id="image-lightbox" class="image-lightbox">
        <form method="dialog" class="lightbox-top">
          <button type="submit" aria-label="关闭图片">关闭</button>
        </form>
        <img id="lightbox-image" src="" alt="" />
        <p id="lightbox-caption"></p>
        <div class="lightbox-actions">
          <button id="lightbox-prev" type="button">上一张</button>
          <button id="lightbox-next" type="button">下一张</button>
        </div>
      </dialog>
    </main>

    <Footer />

    <script>
      import '../scripts/menu.js';
    </script>
    <script type="module" define:vars={{ reviewImages }}>
      const qaGrid = document.getElementById('qa-grid');
      const examList = document.getElementById('exam-list');
      const examStats = document.getElementById('exam-stats');
      const examQuestion = document.getElementById('exam-question');
      const examAnswer = document.getElementById('exam-answer');
      const examShowAnswerButton = document.getElementById('exam-show-answer');
      const examMarkDoneButton = document.getElementById('exam-mark-done');
      const examMarkAgainButton = document.getElementById('exam-mark-again');
      const examNextQuestionButton =
        document.getElementById('exam-next-question');

      const summarySearch = document.getElementById('summary-search');
      const summaryCount = document.getElementById('summary-count');
      const summaryList = document.getElementById('summary-list');
      const summaryDetail = document.getElementById('summary-detail');

      const essayGrid = document.getElementById('essay-grid');
      const essayStats = document.getElementById('essay-stats');
      const essayQuestion = document.getElementById('essay-question');
      const essayHint = document.getElementById('essay-hint');
      const essayShowHintButton = document.getElementById('essay-show-hint');
      const essayMarkDoneButton = document.getElementById('essay-mark-done');
      const essayMarkAgainButton = document.getElementById('essay-mark-again');
      const essayNextQuestionButton = document.getElementById(
        'essay-next-question',
      );

      const glossaryCount = document.getElementById('glossary-count');
      const glossaryList = document.getElementById('glossary-list');
      const glossaryDetail = document.getElementById('glossary-detail');

      const quizStats = document.getElementById('quiz-stats');
      const quizQuestion = document.getElementById('quiz-question');
      const quizAnswer = document.getElementById('quiz-answer');
      const showAnswerButton = document.getElementById('show-answer');
      const markKnownButton = document.getElementById('mark-known');
      const markAgainButton = document.getElementById('mark-again');
      const nextQuestionButton = document.getElementById('next-question');

      const lightbox = document.getElementById('image-lightbox');
      const lightboxImage = document.getElementById('lightbox-image');
      const lightboxCaption = document.getElementById('lightbox-caption');
      const lightboxPrev = document.getElementById('lightbox-prev');
      const lightboxNext = document.getElementById('lightbox-next');

      let allFlashcards = [];
      let deck = [];
      let currentCard = null;
      let totalAnswered = 0;
      let knownCount = 0;

      let allExamQuestions = [];
      let examDeck = [];
      let currentExamQuestion = null;
      let examAnswered = 0;
      let examCompleted = 0;

      let allSummaryRows = { headers: [], rows: [] };
      let allEssayQuestions = [];
      let allGlossaryEntries = [];
      let essayDeck = [];
      let currentEssayQuestion = null;
      let essayAnswered = 0;
      let essayCompleted = 0;

      const galleryImages = Array.from(
        document.querySelectorAll('[data-gallery-image="true"]'),
      );
      let currentImageIndex = 0;

      const shuffle = (items) => {
        const arr = [...items];
        for (let i = arr.length - 1; i > 0; i -= 1) {
          const j = Math.floor(Math.random() * (i + 1));
          [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
      };

      const parseFlashcards = (raw) =>
        raw
          .split(/\r?\n/)
          .map((line) => line.trim())
          .filter(Boolean)
          .map((line) => {
            const splitIndex = line.indexOf(',');
            if (splitIndex < 0) {
              return null;
            }

            return {
              question: line.slice(0, splitIndex).trim(),
              answer: line.slice(splitIndex + 1).trim(),
            };
          })
          .filter(Boolean);

      const parseExamQuestions = (raw) => {
        const lines = raw.split(/\r?\n/).map((line) => line.trim());
        const questionLines = [];
        const answerLines = [];
        let inQuestionSection = false;
        let inAnswerSection = false;

        lines.forEach((line) => {
          if (!line) {
            return;
          }

          if (line.startsWith('#### 第一部分')) {
            inQuestionSection = true;
            inAnswerSection = false;
            return;
          }

          if (line.startsWith('#### 第二部分')) {
            inQuestionSection = false;
            inAnswerSection = true;
            return;
          }

          if (line.startsWith('####')) {
            inQuestionSection = false;
            inAnswerSection = false;
            return;
          }

          if (inQuestionSection) {
            const match = line.match(/^(?:\d+\.\s*)?\*\*(.+)\*\*$/);
            if (match) {
              questionLines.push(match[1].trim());
            }
          }

          if (inAnswerSection) {
            const match = line.match(/^\*\*(.+?)答案：\*\*\s*(.+)$/);
            if (match) {
              answerLines.push({
                title: match[1].trim(),
                answer: match[2].trim(),
              });
            }
          }
        });

        return questionLines.map((question, index) => ({
          question,
          answer: answerLines[index]?.answer ?? '暂无参考答案',
          title: answerLines[index]?.title ?? question,
        }));
      };

      const parseSummary = (raw) => {
        const lines = raw
          .split(/\r?\n/)
          .map((line) => line.trim())
          .filter(Boolean);

        const headers = lines[0]?.split('\t').map((cell) => cell.trim()) ?? [];
        const rows = lines
          .slice(1)
          .map((line) => line.split('\t').map((cell) => cell.trim()));
        return { headers, rows };
      };

      const parseEssayQuestions = (raw) => {
        const lines = raw.split(/\r?\n/).map((line) => line.trim());
        const questions = [];
        let inEssaySection = false;

        lines.forEach((line) => {
          if (!line) {
            return;
          }

          if (line.startsWith('#### 第三部分')) {
            inEssaySection = true;
            return;
          }

          if (line.startsWith('#### 第四部分')) {
            inEssaySection = false;
            return;
          }

          if (!inEssaySection) {
            return;
          }

          const match = line.match(/^\*\*(.+?)\*\*$/);
          if (match) {
            questions.push(match[1].trim());
          }
        });

        return questions;
      };

      const parseGlossary = (raw) => {
        const lines = raw.split(/\r?\n/).map((line) => line.trim());
        const entries = [];
        let inGlossarySection = false;

        lines.forEach((line) => {
          if (!line) {
            return;
          }

          if (line.startsWith('#### 第四部分')) {
            inGlossarySection = true;
            return;
          }

          if (!inGlossarySection) {
            return;
          }

          if (line === '术语,定义/临床意义') {
            return;
          }

          const splitIndex = line.indexOf(',');
          if (splitIndex < 0) {
            return;
          }

          entries.push({
            term: line.slice(0, splitIndex).trim(),
            definition: line.slice(splitIndex + 1).trim(),
          });
        });

        return entries;
      };

      const renderFlashcards = (cards) => {
        qaGrid.innerHTML = '';
        cards.forEach((card) => {
          const details = document.createElement('details');
          details.className = 'qa-card';

          const summary = document.createElement('summary');
          summary.textContent = card.question;

          const answer = document.createElement('p');
          answer.textContent = card.answer;

          details.append(summary, answer);
          qaGrid.append(details);
        });
      };

      const renderExamQuestions = (questions) => {
        examList.innerHTML = '';
        questions.forEach((card) => {
          const details = document.createElement('details');
          details.className = 'qa-card exam-card';

          const summary = document.createElement('summary');
          summary.textContent = card.question;

          const answer = document.createElement('p');
          answer.textContent = card.answer;

          details.append(summary, answer);
          examList.append(details);
        });
      };

      const renderSummaryList = ({ headers, rows }) => {
        if (!headers.length) {
          summaryList.innerHTML = '<li>暂未解析到汇总数据。</li>';
          summaryDetail.innerHTML = '<h3>暂无详情</h3>';
          return;
        }

        summaryList.innerHTML = '';
        const buttons = [];

        const showSummaryDetail = (row, diseaseName, button) => {
          summaryDetail.innerHTML = '';

          const title = document.createElement('h3');
          title.textContent = diseaseName;
          summaryDetail.append(title);

          headers.forEach((header, index) => {
            if (index === 0) return;
            const p = document.createElement('p');
            const strong = document.createElement('strong');
            strong.textContent = `${header}：`;
            p.append(strong, document.createTextNode(row[index] ?? ''));
            summaryDetail.append(p);
          });

          buttons.forEach((item) => item.removeAttribute('data-active'));
          button.setAttribute('data-active', 'true');
        };

        rows.forEach((row, rowIndex) => {
          const diseaseName = row[0] || `疾病 ${rowIndex + 1}`;
          const li = document.createElement('li');
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'disease-button disease-chip';
          button.textContent = diseaseName;

          const size = Math.max(
            0.92,
            Math.min(1.22, 0.94 + diseaseName.length / 18),
          );
          button.style.fontSize = `${size}rem`;

          button.addEventListener('click', () => {
            showSummaryDetail(row, diseaseName, button);
          });

          li.append(button);
          summaryList.append(li);
          buttons.push(button);
        });

        summaryCount.textContent = `共 ${rows.length} 条`;

        if (rows.length) {
          const firstButton = buttons[0];
          showSummaryDetail(rows[0], rows[0][0] || '首项疾病', firstButton);
        }
      };

      const renderEssayQuestions = (questions) => {
        essayGrid.innerHTML = '';

        if (!questions.length) {
          essayGrid.innerHTML = '<p>暂未解析到综合论述题。</p>';
          return;
        }

        questions.forEach((question, index) => {
          const article = document.createElement('article');
          article.className = 'essay-card';

          const label = document.createElement('span');
          label.className = 'essay-index';
          label.textContent = `论述题 ${index + 1}`;

          const text = document.createElement('p');
          text.textContent = question;

          article.append(label, text);
          essayGrid.append(article);
        });
      };

      const updateEssayStats = () => {
        essayStats.textContent = `已练习 ${essayAnswered} 题，完成 ${essayCompleted} 题，题库总计 ${allEssayQuestions.length} 题`;
      };

      const nextEssayCard = () => {
        if (!essayDeck.length) {
          essayDeck = shuffle(allEssayQuestions);
        }

        currentEssayQuestion = essayDeck.pop() ?? null;

        if (!currentEssayQuestion) {
          essayQuestion.textContent = '暂无综合论述题';
          essayHint.hidden = true;
          return;
        }

        essayQuestion.textContent = currentEssayQuestion;
        essayHint.hidden = true;
        essayShowHintButton.textContent = '显示答题提示';
      };

      const initEssayQuiz = (questions) => {
        allEssayQuestions = questions;
        essayDeck = shuffle(questions);
        essayAnswered = 0;
        essayCompleted = 0;
        updateEssayStats();
        nextEssayCard();
      };

      const renderGlossary = (entries) => {
        glossaryList.innerHTML = '';

        if (!entries.length) {
          glossaryList.innerHTML = '<li>暂未解析到核心术语。</li>';
          glossaryDetail.innerHTML = '<h3>暂无详情</h3>';
          return;
        }

        const buttons = [];

        const showGlossaryDetail = (entry, button) => {
          glossaryDetail.innerHTML = '';

          const title = document.createElement('h3');
          title.textContent = entry.term;
          glossaryDetail.append(title);

          const text = document.createElement('p');
          text.textContent = entry.definition;
          glossaryDetail.append(text);

          buttons.forEach((item) => item.removeAttribute('data-active'));
          button.setAttribute('data-active', 'true');
        };

        entries.forEach((entry) => {
          const li = document.createElement('li');
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'disease-button disease-chip glossary-chip';
          button.textContent = entry.term;

          const size = Math.max(
            0.9,
            Math.min(1.15, 0.92 + entry.term.length / 24),
          );
          button.style.fontSize = `${size}rem`;

          button.addEventListener('click', () => {
            showGlossaryDetail(entry, button);
          });

          li.append(button);
          glossaryList.append(li);
          buttons.push(button);
        });

        glossaryCount.textContent = `共 ${entries.length} 条`;

        if (entries.length) {
          showGlossaryDetail(entries[0], buttons[0]);
        }
      };

      const updateQuizStats = () => {
        const total = allFlashcards.length;
        quizStats.textContent = `已练习 ${totalAnswered} 题，记住 ${knownCount} 题，题库总计 ${total} 题`;
      };

      const nextCard = () => {
        if (!deck.length) {
          deck = shuffle(allFlashcards);
        }

        currentCard = deck.pop() ?? null;
        if (!currentCard) {
          quizQuestion.textContent = '暂无题目';
          quizAnswer.hidden = true;
          return;
        }

        quizQuestion.textContent = currentCard.question;
        quizAnswer.textContent = currentCard.answer;
        quizAnswer.hidden = true;
        showAnswerButton.textContent = '显示答案';
      };

      const initQuiz = (cards) => {
        allFlashcards = cards;
        deck = shuffle(cards);
        totalAnswered = 0;
        knownCount = 0;
        updateQuizStats();
        nextCard();
      };

      const updateExamStats = () => {
        examStats.textContent = `已练习 ${examAnswered} 题，完成 ${examCompleted} 题，题库总计 ${allExamQuestions.length} 题`;
      };

      const nextExamCard = () => {
        if (!examDeck.length) {
          examDeck = shuffle(allExamQuestions);
        }

        currentExamQuestion = examDeck.pop() ?? null;

        if (!currentExamQuestion) {
          examQuestion.textContent = '暂无考核题';
          examAnswer.hidden = true;
          return;
        }

        examQuestion.textContent = currentExamQuestion.question;
        examAnswer.textContent = currentExamQuestion.answer;
        examAnswer.hidden = true;
        examShowAnswerButton.textContent = '显示答题提示';
      };

      const initExamQuiz = (questions) => {
        allExamQuestions = questions;
        examDeck = shuffle(questions);
        examAnswered = 0;
        examCompleted = 0;
        updateExamStats();
        nextExamCard();
      };

      showAnswerButton.addEventListener('click', () => {
        const nextHidden = !quizAnswer.hidden;
        quizAnswer.hidden = nextHidden;
        showAnswerButton.textContent = nextHidden ? '显示答案' : '隐藏答案';
      });

      markKnownButton.addEventListener('click', () => {
        if (!currentCard) return;
        knownCount += 1;
        totalAnswered += 1;
        updateQuizStats();
        nextCard();
      });

      markAgainButton.addEventListener('click', () => {
        if (!currentCard) return;
        deck.unshift(currentCard);
        totalAnswered += 1;
        updateQuizStats();
        nextCard();
      });

      nextQuestionButton.addEventListener('click', () => {
        if (!currentCard) return;
        totalAnswered += 1;
        updateQuizStats();
        nextCard();
      });

      essayShowHintButton.addEventListener('click', () => {
        const nextHidden = !essayHint.hidden;
        essayHint.hidden = nextHidden;
        essayShowHintButton.textContent = nextHidden
          ? '显示答题提示'
          : '隐藏答题提示';
      });

      essayMarkDoneButton.addEventListener('click', () => {
        if (!currentEssayQuestion) return;
        essayAnswered += 1;
        essayCompleted += 1;
        updateEssayStats();
        nextEssayCard();
      });

      essayMarkAgainButton.addEventListener('click', () => {
        if (!currentEssayQuestion) return;
        essayDeck.unshift(currentEssayQuestion);
        essayAnswered += 1;
        updateEssayStats();
        nextEssayCard();
      });

      essayNextQuestionButton.addEventListener('click', () => {
        if (!currentEssayQuestion) return;
        essayAnswered += 1;
        updateEssayStats();
        nextEssayCard();
      });

      examShowAnswerButton.addEventListener('click', () => {
        const nextHidden = !examAnswer.hidden;
        examAnswer.hidden = nextHidden;
        examShowAnswerButton.textContent = nextHidden
          ? '显示答题提示'
          : '隐藏答题提示';
      });

      examMarkDoneButton.addEventListener('click', () => {
        if (!currentExamQuestion) return;
        examAnswered += 1;
        examCompleted += 1;
        updateExamStats();
        nextExamCard();
      });

      examMarkAgainButton.addEventListener('click', () => {
        if (!currentExamQuestion) return;
        examDeck.unshift(currentExamQuestion);
        examAnswered += 1;
        updateExamStats();
        nextExamCard();
      });

      examNextQuestionButton.addEventListener('click', () => {
        if (!currentExamQuestion) return;
        examAnswered += 1;
        updateExamStats();
        nextExamCard();
      });

      const showLightboxAt = (index) => {
        currentImageIndex = index;
        const img = reviewImages[currentImageIndex];
        lightboxImage.src = img.src;
        lightboxImage.alt = img.alt;
        lightboxCaption.textContent = img.alt;
        if (!lightbox.open) {
          lightbox.showModal();
        }
      };

      galleryImages.forEach((img, index) => {
        img.addEventListener('click', () => showLightboxAt(index));
      });

      lightboxPrev.addEventListener('click', () => {
        currentImageIndex =
          (currentImageIndex - 1 + reviewImages.length) % reviewImages.length;
        showLightboxAt(currentImageIndex);
      });

      lightboxNext.addEventListener('click', () => {
        currentImageIndex = (currentImageIndex + 1) % reviewImages.length;
        showLightboxAt(currentImageIndex);
      });

      summarySearch.addEventListener('input', () => {
        const keyword = summarySearch.value.trim().toLowerCase();
        if (!keyword) {
          renderSummaryList(allSummaryRows);
          return;
        }

        const filteredRows = allSummaryRows.rows.filter((row) =>
          (row[0] ?? '').toLowerCase().includes(keyword),
        );

        renderSummaryList({
          headers: allSummaryRows.headers,
          rows: filteredRows,
        });
      });

      const loadReviewContent = async () => {
        try {
          const [flashcardRaw, examGuideRaw, summaryRaw] = await Promise.all([
            fetch('/闪卡.md').then((res) => res.text()),
            fetch('/临床技能考试综合复习指南.md').then((res) => res.text()),
            fetch('/汇总.md').then((res) => res.text()),
          ]);

          const cards = parseFlashcards(flashcardRaw);
          const questions = parseExamQuestions(examGuideRaw);
          const summary = parseSummary(summaryRaw);
          const essayQuestions = parseEssayQuestions(examGuideRaw);
          const glossaryEntries = parseGlossary(examGuideRaw);

          renderFlashcards(cards);
          renderExamQuestions(questions);
          renderSummaryList(summary);
          renderEssayQuestions(essayQuestions);
          renderGlossary(glossaryEntries);
          initQuiz(cards);
          initExamQuiz(questions);
          initEssayQuiz(essayQuestions);
          allSummaryRows = summary;
          allEssayQuestions = essayQuestions;
          allGlossaryEntries = glossaryEntries;
        } catch (error) {
          qaGrid.innerHTML = '<p>加载闪卡失败，请稍后重试。</p>';
          examList.innerHTML = '<li>加载考核题失败，请稍后重试。</li>';
          examStats.textContent = '加载考核题失败，请稍后重试。';
          summaryList.innerHTML = '<li>加载疾病列表失败，请稍后重试。</li>';
          summaryDetail.innerHTML = '<h3>加载详情失败</h3>';
          essayGrid.innerHTML = '<p>加载综合论述失败，请稍后重试。</p>';
          essayStats.textContent = '加载综合论述失败，请稍后重试。';
          glossaryList.innerHTML = '<li>加载核心术语失败，请稍后重试。</li>';
          glossaryDetail.innerHTML = '<h3>加载详情失败</h3>';
        }
      };

      loadReviewContent();
    </script>
  </body>
