---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.pubDate);
const dateLabel = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
const dateLabelEn = date.toLocaleDateString('en', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<BaseLayout
  pageTitle={frontmatter.title}
  description={frontmatter.description}
  pageClass="portfolio-page article-portfolio-page"
>
  <main class="page-shell article-shell">
    <nav
      class="article-nav-bar"
      aria-label="Article navigation"
      data-i18n-aria-en="Article navigation"
      data-i18n-aria-zh="文章导航"
    >
      <a href="/blog/" data-i18n-en="Back to Blog" data-i18n-zh="返回博客">
        Back to Blog
      </a>
      <a href="/blog/#all" data-i18n-en="All posts" data-i18n-zh="全部文章">
        All posts
      </a>
      <a href="/" data-i18n-en="Home" data-i18n-zh="首页">Home</a>
    </nav>

    <div class="article-layout">
      <article class="article-page">
        <header class="article-header">
          <p class="section-label" data-i18n-en="Writing" data-i18n-zh="写作">
            Writing
          </p>
          <div class="article-meta">
            <time
              datetime={date.toISOString()}
              data-i18n-en={dateLabelEn}
              data-i18n-zh={dateLabel}
            >
              {dateLabelEn}
            </time>
            {frontmatter.author && <span>{frontmatter.author}</span>}
          </div>
          <h1>{frontmatter.title}</h1>
          {frontmatter.description && <p>{frontmatter.description}</p>}
          {
            frontmatter.tags && (
              <div class="post-tags">
                {frontmatter.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            )
          }
        </header>
        {
          frontmatter.image?.url && (
            <img
              class="article-image"
              src={frontmatter.image.url}
              alt={frontmatter.image.alt || ''}
            />
          )
        }
        <div class="article-content" id="article-content">
          <slot />
        </div>
      </article>

      <aside
        class="article-sidebar"
        aria-label="Table of contents"
        data-i18n-aria-en="Table of contents"
        data-i18n-aria-zh="文章目录"
      >
        <div class="article-toc-card">
          <p class="panel-title" data-i18n-en="Contents" data-i18n-zh="目录">
            Contents
          </p>
          <nav id="article-toc" class="article-toc"></nav>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const content = document.querySelector('#article-content');
    const toc = document.querySelector('#article-toc');
    const headings = content
      ? Array.from(content.querySelectorAll('h2, h3'))
      : [];

    if (toc && headings.length > 0) {
      headings.forEach((heading, index) => {
        const text = heading.textContent?.trim();
        if (!text) return;

        const id =
          heading.id ||
          text
            .toLowerCase()
            .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
            .replace(/^-|-$/g, '') ||
          `section-${index + 1}`;

        heading.id = id;

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = text;
        link.className =
          heading.tagName.toLowerCase() === 'h3' ? 'toc-child' : '';
        toc.appendChild(link);
      });
    } else {
      document.querySelector('.article-sidebar')?.remove();
    }
  </script>
</BaseLayout>
